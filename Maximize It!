from itertools import product

K, M = map(int, input().split())

lists = []
for _ in range(K):
    data = list(map(int, input().split()))
    lists.append(data[1:]) 

max_val = 0
for combo in product(*lists):
    val = sum(x**2 for x in combo) % M
    if val > max_val:
        max_val = val

print(max_val)
